# GHCR read/write credentials used by the publish script or by your server.
GHCR_USERNAME=
GHCR_TOKEN=

# Published image reference.
SPORTS_API_IMAGE=ghcr.io/olivermarcusson/euripus-sports-api
SPORTS_API_IMAGE_TAG=selfhosted-latest

# Optional deployment overrides for compose.selfhosted.yml.
SPORTS_API_PORT=3000
SPORTS_API_SOURCE_FETCH_MODE=auto
SPORTS_API_BROWSER_COMMAND=chromium
SPORTS_API_REFRESH_INTERVAL=10m
